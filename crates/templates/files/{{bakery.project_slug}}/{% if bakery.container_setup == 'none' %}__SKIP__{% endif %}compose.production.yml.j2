name: {{ bakery.project_slug }}_production

services:
  django: &django
    build:
      context: .
      dockerfile: compose/production/django/Dockerfile
    image: {{ bakery.project_slug }}_production_django
    env_file:
      - .env
    environment:
      DJANGO_SETTINGS_MODULE: config.settings.production
    depends_on:
{%- if bakery.is_postgres %}
      postgres:
        condition: service_healthy
{%- elif bakery.is_mysqlish %}
      mysql:
        condition: service_healthy
{%- endif %}
{%- if bakery.use_celery and bakery.celery_broker == 'redis' %}
      redis:
        condition: service_started
{%- endif %}
    command: /start
    restart: unless-stopped
{%- if bakery.container_setup == 'compose-traefik' %}
    labels:
      - "traefik.enable=true"
      - "traefik.http.routers.web.rule=Host(`{{ bakery.domain_name }}`)"
      - "traefik.http.routers.web.entrypoints=websecure"
      - "traefik.http.routers.web.tls=true"
      - "traefik.http.routers.web.tls.certresolver=letsencrypt"
      - "traefik.http.services.web.loadbalancer.server.port=5000"
{%- else %}
    ports:
      - "5000:5000"
{%- endif %}

{%- if bakery.is_postgres %}

  postgres:
    build:
      context: .
      dockerfile: compose/production/postgres/Dockerfile
    image: {{ bakery.project_slug }}_production_postgres
    env_file:
      - .env
    volumes:
      - production_postgres_data:/var/lib/postgresql/data
      - production_postgres_data_backups:/backups
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U postgres -d {{ bakery.project_slug }}"]
      interval: 10s
      timeout: 5s
      retries: 6
    restart: unless-stopped
{%- endif %}

{%- if bakery.is_mysqlish %}

  mysql:
    # Official image (named `mysql` to match DATABASE_URL's host). MySQL 9 and
    # MariaDB LTS both accept the MYSQL_* init vars and `mysqladmin ping`.
{%- if bakery.is_mariadb %}
    image: mariadb:lts
{%- else %}
    image: mysql:9
{%- endif %}
    env_file:
      - .env
    environment:
      MYSQL_DATABASE: ${MYSQL_DATABASE:-{{ bakery.project_slug }}}
    volumes:
      - production_mysql_data:/var/lib/mysql
    healthcheck:
{%- if bakery.is_mariadb %}
      # MariaDB ships `healthcheck.sh` (no `mysqladmin` binary).
      test: ["CMD", "healthcheck.sh", "--connect", "--innodb_initialized"]
{%- else %}
      test: ["CMD-SHELL", "mysqladmin ping -h 127.0.0.1 -uroot -p${MYSQL_ROOT_PASSWORD} --silent"]
{%- endif %}
      interval: 10s
      timeout: 5s
      retries: 6
    restart: unless-stopped
{%- endif %}

{%- if bakery.use_celery and bakery.celery_broker == 'redis' %}

  redis:
    image: redis:8-alpine
    # Password comes from the gitignored .env (REDIS_PASSWORD). Compose's $$ escape
    # passes the literal `${REDIS_PASSWORD}` to the container's entrypoint, which
    # the container's shell then resolves from its environment.
    command: redis-server --requirepass $${REDIS_PASSWORD} --appendonly yes
    env_file:
      - .env
    volumes:
      - production_redis_data:/data
    restart: unless-stopped
{%- endif %}

{%- if bakery.use_celery %}

  celery_worker:
    <<: *django
    image: {{ bakery.project_slug }}_production_celery_worker
    command: /start-celeryworker
    labels: []
    ports: []

  celery_beat:
    <<: *django
    image: {{ bakery.project_slug }}_production_celery_beat
    command: /start-celerybeat
    labels: []
    ports: []
{%- endif %}

{%- if bakery.container_setup == 'compose-traefik' %}

  traefik:
    build:
      context: .
      dockerfile: compose/production/traefik/Dockerfile
    image: {{ bakery.project_slug }}_production_traefik
    depends_on:
      - django
    volumes:
      - production_traefik:/etc/traefik/acme
    ports:
      - "80:80"
      - "443:443"
    restart: unless-stopped
{%- endif %}

volumes:
{%- if bakery.is_postgres %}
  production_postgres_data: {}
  production_postgres_data_backups: {}
{%- endif %}
{%- if bakery.is_mysqlish %}
  production_mysql_data: {}
{%- endif %}
{%- if bakery.use_celery and bakery.celery_broker == 'redis' %}
  production_redis_data: {}
{%- endif %}
{%- if bakery.container_setup == 'compose-traefik' %}
  production_traefik: {}
{%- endif %}
