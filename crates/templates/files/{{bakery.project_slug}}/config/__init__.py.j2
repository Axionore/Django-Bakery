{%- if bakery.is_mysqlish %}
# PyMySQL is a pure-Python MySQL driver ‚Äî no native build deps required, works
# on any developer machine without `libmariadb-dev` / `mysql-client-dev`.
# Django expects `MySQLdb` (the historical name from `mysqlclient`); this shim
# rebinds PyMySQL under that name so the rest of the stack stays unchanged.
# Must run before Django's `mysql` backend imports `MySQLdb`, so it lives in
# the project root package's `__init__.py`.
import pymysql

pymysql.install_as_MySQLdb()
{%- endif %}
