"""Base Django settings — shared across every environment.

The split is base.py → local.py | production.py | test.py. Each leaf settings module
imports `*` from this file and overrides what it needs. Environment-specific secrets
come from `.env*` files via django-environ.
"""

from __future__ import annotations

from pathlib import Path

import environ

BASE_DIR = Path(__file__).resolve().parents[2]
APPS_DIR = BASE_DIR / "apps"

env = environ.Env()
env_file = BASE_DIR / ".env"
if env_file.is_file():
    env.read_env(str(env_file))

# ---------------------------------------------------------------------------
# Core
# ---------------------------------------------------------------------------
SECRET_KEY = env("DJANGO_SECRET_KEY", default=None)
if not SECRET_KEY:
    # In dev only (DJANGO_DEBUG=True), generate an in-memory throwaway so `manage.py check`
    # works on a fresh clone. NEVER reachable in production — production settings load
    # this module first and would have died on the env() lookup above if DJANGO_SECRET_KEY
    # wasn't set (we removed the default).
    if env.bool("DJANGO_DEBUG", default=False):
        import secrets as _secrets

        SECRET_KEY = _secrets.token_urlsafe(50)
    else:
        from django.core.exceptions import ImproperlyConfigured

        raise ImproperlyConfigured(
            "DJANGO_SECRET_KEY must be set in production (no fallback). "
            "See .env.example for the expected variable name."
        )
DEBUG = env.bool("DJANGO_DEBUG", default=False)
ALLOWED_HOSTS = env.list("DJANGO_ALLOWED_HOSTS", default=["localhost", "0.0.0.0", "127.0.0.1"])

