{%- if bakery.multi_tenant %}
# Multi-tenant mode (django-tenants). Apps split into:
#   SHARED_APPS — live in the `public` schema, accessible to all tenants
#                 (auth, sessions, admin, tenants/domains lookup tables).
#   TENANT_APPS — installed per-schema, your business models live here.
# `django_tenants` must be FIRST in SHARED_APPS so its post_migrate signal
# wins over Django's; `apps.tenants` must come next (the routing table).
SHARED_APPS = [
    "django_tenants",
    "apps.tenants",
] + DJANGO_APPS + THIRD_PARTY_APPS + [
    "apps.users",
    "apps.core",
]
TENANT_APPS = [
    "django.contrib.contenttypes",
{%- if bakery.api_layer != 'none' %}
    "apps.api",
{%- endif %}
{%- if bakery.graph_db != 'none' %}
    "apps.graph",
{%- endif %}
]
# INSTALLED_APPS is the union — order matters; django-tenants first wins.
# Preserve SHARED_APPS' order (django_tenants is first by construction) and
# append only the tenant-scoped apps that aren't already shared. A set-flatten
# would destroy ordering — Python `set` iteration is hash-based, so
# `list({…})` returns elements in implementation-defined order; on multi-tenant
# projects that loses the `django_tenants must be first` invariant.
INSTALLED_APPS = SHARED_APPS + [app for app in TENANT_APPS if app not in SHARED_APPS]
TENANT_MODEL = "tenants.Tenant"
TENANT_DOMAIN_MODEL = "tenants.Domain"
{%- else %}
INSTALLED_APPS = DJANGO_APPS + THIRD_PARTY_APPS + LOCAL_APPS
{%- endif %}

