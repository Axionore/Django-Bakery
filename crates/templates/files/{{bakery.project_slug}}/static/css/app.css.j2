{%- if bakery.css_framework == 'tailwind' %}
/* Tailwind v4 — CSS-first configuration. */
@import "tailwindcss";

@theme {
  --color-brand-50:  oklch(0.97 0.02 250);
  --color-brand-100: oklch(0.93 0.04 250);
  --color-brand-300: oklch(0.80 0.10 250);
  --color-brand-500: oklch(0.55 0.18 250);
  --color-brand-700: oklch(0.38 0.16 250);
  --color-brand-900: oklch(0.20 0.10 250);

  --font-sans: "Inter", ui-sans-serif, system-ui, -apple-system, "Segoe UI", Roboto, sans-serif;
  --font-mono: "JetBrains Mono", ui-monospace, SFMono-Regular, "SF Mono", Menlo, monospace;

  --radius-card: 0.75rem;
}

/* Project-specific tweaks live here. */
.prose :where(a) {
  text-decoration: underline;
  text-decoration-thickness: 0.08em;
  text-underline-offset: 0.18em;
}
{%- elif bakery.css_framework == 'bootstrap' %}
/* Bootstrap 5 is imported from node_modules / CDN — only project overrides go here. */
@import "bootstrap/dist/css/bootstrap.min.css";

:root {
  --bs-body-font-family: "Inter", system-ui, sans-serif;
}
{%- else %}
/* Bring-your-own CSS. */
:root {
  color-scheme: light dark;
  font-family: system-ui, -apple-system, "Segoe UI", Roboto, sans-serif;
  line-height: 1.5;
}
body { margin: 0; padding: 1rem; }
{%- endif %}
