import "~/assets/css/main.css";

import { createApp } from "vue";
import { createPinia } from "pinia";
{%- if bakery.use_sentry %}
import * as Sentry from "@sentry/vue";
{%- endif %}

import App from "~/App.vue";
import { router } from "~/router";
import { useAuthStore } from "~/stores/auth";

const app = createApp(App);
const pinia = createPinia();

app.use(pinia);
app.use(router);

{%- if bakery.use_sentry %}
if (import.meta.env.VITE_SENTRY_DSN) {
  Sentry.init({
    app,
    dsn: import.meta.env.VITE_SENTRY_DSN,
    environment: import.meta.env.MODE,
    integrations: [Sentry.browserTracingIntegration({ router })],
    tracesSampleRate: 0.1,
    // Defense in depth: strip credentials before the event leaves the SPA.
    beforeSend(event) {
      if (event.request?.cookies) delete event.request.cookies;
      if (event.request?.headers) {
        delete event.request.headers["Cookie"];
        delete event.request.headers["Authorization"];
        delete event.request.headers["X-CSRFToken"];
      }
      return event;
    },
  });
}
{%- endif %}

// Hydrate the auth store before the first <RouterView> renders so route
// guards have something to check.
const auth = useAuthStore(pinia);
auth.refresh().finally(() => {
  app.mount("#app");
});
