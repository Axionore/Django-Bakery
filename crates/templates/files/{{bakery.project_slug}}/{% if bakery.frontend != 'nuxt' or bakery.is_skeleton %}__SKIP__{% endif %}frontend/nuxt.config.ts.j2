import { defineNuxtConfig } from "nuxt/config";
import tailwindcss from "@tailwindcss/vite";

// https://nuxt.com/docs/api/configuration/nuxt-config
export default defineNuxtConfig({
  compatibilityDate: "2026-05-27",
  future: { compatibilityVersion: 4 },
  devtools: { enabled: true },

  modules: [
    "@nuxt/eslint",
    "@pinia/nuxt",
    "@vueuse/nuxt",
{%- if bakery.use_sentry %}
    "@sentry/nuxt/module",
{%- endif %}
  ],

  // Tailwind v4 — uses the `@tailwindcss/vite` plugin instead of the legacy
  // `@nuxtjs/tailwindcss` (Nuxt module), which is still pinned to Tailwind v3
  // and breaks the build with "tailwindcss directly as PostCSS plugin".
  css: ["~/assets/css/main.css"],
  vite: { plugins: [tailwindcss()] },

  typescript: { strict: true, typeCheck: false },
  devServer: { port: {{ bakery.frontend_dev_port }}, host: "0.0.0.0" },

  app: {
    head: {
      title: "{{ bakery.project_name }}",
      meta: [
        { charset: "utf-8" },
        { name: "viewport", content: "width=device-width, initial-scale=1" },
        { name: "description", content: "{{ bakery.description }}" },
      ],
      link: [
        { rel: "icon", type: "image/svg+xml", href: "/favicon.svg" },
      ],
    },
  },

  // Nitro routeRules — keep /api + /_allauth same-origin so cookies + CSRF Just Work.
  // (OWASP A05 — no wildcard CORS; the SPA never sees foreign-origin responses.)
  routeRules: {
    "/api/**": { proxy: `${process.env.NITRO_BACKEND_URL ?? "http://localhost:8000"}/api/**` },
    "/_allauth/**": { proxy: `${process.env.NITRO_BACKEND_URL ?? "http://localhost:8000"}/_allauth/**` },
    "/static/**": { proxy: `${process.env.NITRO_BACKEND_URL ?? "http://localhost:8000"}/static/**` },
    "/media/**": { proxy: `${process.env.NITRO_BACKEND_URL ?? "http://localhost:8000"}/media/**` },
  },

  // OWASP A09 — don't ship source maps to production.
  sourcemap: { server: false, client: false },

  runtimeConfig: {
    public: {
      appName: "{{ bakery.project_name }}",
{%- if bakery.use_sentry %}
      sentryDsn: process.env.NUXT_PUBLIC_SENTRY_DSN ?? "",
{%- endif %}
    },
  },

{%- if bakery.use_sentry %}

  sentry: {
    sourceMapsUploadOptions: { org: "", project: "" },
  },
{%- endif %}

  experimental: { typedPages: true, viewTransition: true },
});
