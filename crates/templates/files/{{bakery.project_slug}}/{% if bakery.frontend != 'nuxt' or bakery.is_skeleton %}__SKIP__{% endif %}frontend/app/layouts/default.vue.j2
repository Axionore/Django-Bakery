<script setup lang="ts">
import "~/assets/css/main.css";

const auth = useAuthStore();
const { user } = storeToRefs(auth);
const router = useRouter();
const projectName = useRuntimeConfig().public.appName;
{% if bakery.api_layer != 'none' %}
const apiDocsHref = "/api/docs";
{% endif %}

// Persisted theme — kept in a cookie so it survives SSR + reloads.
// (No `useColorMode` here: the @vueuse/nuxt auto-imports are inconsistent
// in SSR for v14, and we don't want a separate @nuxtjs/color-mode dep.)
const theme = useCookie<"light" | "dark">("theme", { default: () => "light", sameSite: "lax" });
async function logout() {
  await auth.logout();
  await router.push("/");
}

function toggleTheme() {
  theme.value = theme.value === "dark" ? "light" : "dark";
  if (import.meta.client) document.documentElement.classList.toggle("dark", theme.value === "dark");
}
</script>

<template>
  <div class="flex min-h-dvh flex-col bg-slate-50 text-slate-900 dark:bg-slate-950 dark:text-slate-50">
    <nav class="border-b border-slate-200 dark:border-slate-800">
      <div class="mx-auto flex max-w-5xl items-center justify-between px-4 py-3">
        <div class="flex items-center gap-5">
          <NuxtLink to="/" class="text-base font-semibold tracking-tight no-underline">{{ '{{' }} projectName {{ '}}' }}</NuxtLink>
          <div class="hidden gap-4 text-sm sm:flex">
            <NuxtLink
              to="/"
              class="text-slate-600 dark:text-slate-300"
              exact-active-class="!font-semibold !text-brand-700 dark:!text-brand-300"
            >Home</NuxtLink>
            <NuxtLink
              to="/about"
              class="text-slate-600 dark:text-slate-300"
              active-class="!font-semibold !text-brand-700 dark:!text-brand-300"
            >About</NuxtLink>
{% if bakery.api_layer != 'none' -%}
            <a :href="apiDocsHref" target="_blank" rel="noreferrer" class="text-slate-600 dark:text-slate-300">API</a>
{%- endif %}
          </div>
        </div>
        <div class="flex items-center gap-2 text-sm">
          <button
            type="button"
            class="rounded-md border border-slate-300 px-2 py-1 hover:bg-slate-100 dark:border-slate-700 dark:hover:bg-slate-800"
            :aria-label="theme === 'dark' ? 'Switch to light theme' : 'Switch to dark theme'"
            @click="toggleTheme"
          >
            {{ '{{' }} theme === "dark" ? "☀" : "☾" {{ '}}' }}
          </button>
          <template v-if="user">
            <NuxtLink to="/account/profile" class="rounded-md px-3 py-1 hover:bg-slate-100 dark:hover:bg-slate-800">
              {{ '{{' }} user.email {{ '}}' }}
            </NuxtLink>
            <button
              type="button"
              class="rounded-md bg-slate-900 px-3 py-1 text-white hover:bg-slate-700 dark:bg-slate-100 dark:text-slate-900"
              @click="logout"
            >
              Sign out
            </button>
          </template>
          <template v-else>
            <NuxtLink to="/account/login" class="rounded-md px-3 py-1 hover:bg-slate-100 dark:hover:bg-slate-800">Sign in</NuxtLink>
            <NuxtLink to="/account/signup" class="rounded-md bg-slate-900 px-3 py-1 text-white hover:bg-slate-700 dark:bg-slate-100 dark:text-slate-900">Sign up</NuxtLink>
          </template>
        </div>
      </div>
    </nav>

    <main class="mx-auto w-full max-w-5xl flex-1 px-4 py-8">
      <slot />
    </main>

    <footer class="border-t border-slate-200 dark:border-slate-800">
      <div class="mx-auto flex max-w-5xl items-center justify-between px-4 py-4 text-xs text-slate-500">
        <span>© {{ '{{' }} new Date().getFullYear() {{ '}}' }} · powered by django-bakery</span>
        <a href="https://github.com/Axionore/Django-Bakery" target="_blank" rel="noreferrer">source</a>
      </div>
    </footer>
  </div>
</template>
