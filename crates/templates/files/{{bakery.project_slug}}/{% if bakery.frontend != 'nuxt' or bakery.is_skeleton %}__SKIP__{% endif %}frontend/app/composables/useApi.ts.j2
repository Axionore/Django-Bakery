{%- if bakery.has_typed_api %}
/**
 * Typed API client for the project's `/api/*` endpoints.
 *
 * Backend is {{ bakery.api_layer }} — uses Django session authentication.
 *   - Ninja: https://django-ninja.dev/guides/authentication/
 *   - DRF:   https://www.django-rest-framework.org/api-guide/authentication/
 *
 * Regenerate `app/types/api-schema.d.ts` whenever the backend schema changes:
 *
 *     pnpm openapi:gen
 */

import { useCsrf } from "~/composables/useCsrf";

export class HttpError extends Error {
  constructor(public status: number, public body: unknown) {
    super(`HTTP ${status}`);
    this.name = "HttpError";
  }
}

const BASE = "/api";

export function useApi() {
  const { csrfHeaders } = useCsrf();

  async function get<T>(path: string): Promise<T> {
    const r = await fetch(`${BASE}${path}`, {
      credentials: "include",
      headers: { Accept: "application/json" },
    });
    if (!r.ok) throw new HttpError(r.status, await r.json().catch(() => null));
    return (await r.json()) as T;
  }

  async function send<T>(
    method: "POST" | "PUT" | "PATCH" | "DELETE",
    path: string,
    body?: unknown,
  ): Promise<T> {
    const r = await fetch(`${BASE}${path}`, {
      method,
      credentials: "include",
      headers: csrfHeaders({ Accept: "application/json" }),
      body: body === undefined ? undefined : JSON.stringify(body),
    });
    if (!r.ok) throw new HttpError(r.status, await r.json().catch(() => null));
    if (r.status === 204) return undefined as T;
    return (await r.json()) as T;
  }

  async function fetchMe(): Promise<{
    id: number;
    email: string;
    full_name: string;
    is_staff: boolean;
  }> {
    return get("/me");
  }

  return { get, send, fetchMe };
}
{% else %}
// No API layer was selected for this project. Pick one in the recipe and re-run
// django-bakery to get a typed client here.
export function useApi() {
  return {};
}
{% endif -%}
