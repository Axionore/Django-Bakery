"""GraphQL schema (Graphene-Django).

Mirrors the Strawberry variant's shape: a `UserType` projected from the User
model, and a `me` query that returns the authenticated caller (or `None`
when anonymous). Extend this file with new types + queries as the API grows;
mutations belong in a sibling `mutations.py` module imported into `Mutation`.
"""

from __future__ import annotations

import graphene
from graphene_django import DjangoObjectType

from apps.users.models import User


class UserType(DjangoObjectType):
    """Public projection of the User model — never expose the password hash."""

    class Meta:
        model = User
        fields = ("id", "email", "full_name", "is_staff")


class Query(graphene.ObjectType):
    me = graphene.Field(UserType, description="The authenticated caller, or null when anonymous.")

    def resolve_me(self, info) -> User | None:
        user = info.context.user
        if user.is_anonymous:
            return None
        return user


schema = graphene.Schema(query=Query)
