# pnpm 11+ workspace + settings.
#
# This file replaces the now-deprecated `pnpm` field in `package.json`
# (pnpm 11 emits a warning and ignores it). All per-project settings —
# build-script gates, package overrides, version policies — live here.
{%- if bakery.frontend == 'react' or bakery.frontend == 'vue' or bakery.frontend == 'nuxt' or bakery.frontend == 'next' %}

# `frontend/` is the SPA package; pnpm install at this directory installs both
# the workspace root (currently empty) and the SPA dependency tree.
packages:
  - frontend
{%- else %}

# HTMX + Tailwind: the project root IS the only pnpm package (carries the
# Tailwind CLI build). Listing "." makes pnpm 11 happy without inventing a
# nested package directory.
packages:
  - "."
{%- endif %}

# Allowlist of dependencies whose `postinstall` / build scripts pnpm 11 is
# permitted to run during install. Adding a package here is opt-in to
# arbitrary code execution at install time — keep it tight.
onlyBuiltDependencies:
  - "@parcel/watcher"
  - esbuild
  - unrs-resolver
{%- if bakery.frontend == 'nuxt' %}
  - "@nuxt/icon"
  - vue-demi
{%- elif bakery.frontend == 'next' %}
  - sharp
{%- endif %}
