import type { CSSProperties } from "react";
import { Link, NavLink, useNavigate } from "react-router";
import { Box, Button, Container, DropdownMenu, Flex, IconButton, Text } from "@radix-ui/themes";
import { MoonIcon, SunIcon, PersonIcon } from "@radix-ui/react-icons";

import { useAuth, useLogout } from "~/auth/store";
import { useThemeAppearance } from "~/ui/theme";

const PROJECT_NAME = "{{ bakery.project_name }}";

{% raw %}
const navLinkStyle = ({ isActive }: { isActive: boolean }): CSSProperties => ({
  textDecoration: "none",
  color: isActive ? "var(--accent-11)" : "var(--gray-12)",
  fontWeight: isActive ? 600 : 400,
  fontSize: 14,
});

const externalNavLinkStyle: CSSProperties = {
  textDecoration: "none",
  color: "var(--gray-12)",
  fontSize: 14,
};

export function Nav() {
  const { user } = useAuth();
  const { appearance, toggle } = useThemeAppearance();
  const navigate = useNavigate();
  const logout = useLogout();

  return (
    <Box asChild style={{ borderBottom: "1px solid var(--gray-a4)" }}>
      <nav>
        <Container size="3" px={{ initial: "4", sm: "6" }}>
          <Flex align="center" justify="between" py="3">
            <Flex align="center" gap="5">
              <Text size="3" weight="bold" asChild>
                <Link to="/" style={{ color: "inherit", textDecoration: "none" }}>
                  {PROJECT_NAME}
                </Link>
              </Text>
              <Flex gap="4" align="center" display={{ initial: "none", sm: "flex" }}>
                <NavLink to="/" end style={navLinkStyle}>
                  Home
                </NavLink>
                <NavLink to="/about" style={navLinkStyle}>
                  About
                </NavLink>
{% endraw %}
{%- if bakery.api_layer != 'none' %}
{% raw %}
                <a href="/api/docs" style={externalNavLinkStyle} target="_blank" rel="noreferrer">
                  API
                </a>
{% endraw %}
{%- endif %}
{% raw %}
              </Flex>
            </Flex>
            <Flex align="center" gap="2">
              <IconButton
                variant="ghost"
                aria-label={appearance === "dark" ? "Switch to light theme" : "Switch to dark theme"}
                onClick={toggle}
              >
                {appearance === "dark" ? <SunIcon /> : <MoonIcon />}
              </IconButton>
              {user ? (
                <DropdownMenu.Root>
                  <DropdownMenu.Trigger>
                    <Button variant="soft" size="2">
                      <PersonIcon />
                      {user.email}
                    </Button>
                  </DropdownMenu.Trigger>
                  <DropdownMenu.Content>
                    <DropdownMenu.Item onSelect={() => navigate("/account/profile")}>Profile</DropdownMenu.Item>
                    <DropdownMenu.Item onSelect={() => navigate("/account/mfa-activate")}>
                      MFA settings
                    </DropdownMenu.Item>
                    <DropdownMenu.Separator />
                    <DropdownMenu.Item color="red" onSelect={() => void logout()}>
                      Sign out
                    </DropdownMenu.Item>
                  </DropdownMenu.Content>
                </DropdownMenu.Root>
              ) : (
                <>
                  <Button asChild variant="ghost" size="2">
                    <Link to="/account/login">Sign in</Link>
                  </Button>
                  <Button asChild size="2">
                    <Link to="/account/signup">Sign up</Link>
                  </Button>
                </>
              )}
            </Flex>
          </Flex>
        </Container>
      </nav>
    </Box>
  );
}
{% endraw %}
