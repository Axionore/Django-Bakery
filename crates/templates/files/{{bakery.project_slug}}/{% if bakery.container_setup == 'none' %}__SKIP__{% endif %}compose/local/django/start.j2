#!/usr/bin/env bash
set -euo pipefail

# Custom AUTH_USER_MODEL needs its initial migration before `migrate` runs —
# Django refuses migrations that depend on `users` if the app has no
# migrations directory of its own. After the first boot the generated
# migration is committed to the repo and this becomes a no-op.
{%- if bakery.multi_tenant %}
# Multi-tenant also ships an `apps.tenants` app whose Tenant/Domain models
# need their own initial migration on first boot.
uv run python manage.py makemigrations users tenants --noinput
# django-tenants disables the bare `migrate` command. Shared tables (auth,
# sessions, the tenants registry) live in the `public` schema and migrate
# via `migrate_schemas --shared`. Tenant-scoped apps migrate per-tenant
# later via `migrate_schemas` (no --shared) once tenants exist.
uv run python manage.py migrate_schemas --shared --noinput
# Idempotent first-deploy bootstrap of the `public` Tenant + Domain rows so
# `TenantMainMiddleware` can route the local hostname on the first request.
# After the first run this becomes a no-op (get_or_create).
uv run python manage.py bootstrap_public_tenant
{%- else %}
uv run python manage.py makemigrations users --noinput
uv run python manage.py migrate --noinput
{%- endif %}
uv run python manage.py runserver 0.0.0.0:8000
