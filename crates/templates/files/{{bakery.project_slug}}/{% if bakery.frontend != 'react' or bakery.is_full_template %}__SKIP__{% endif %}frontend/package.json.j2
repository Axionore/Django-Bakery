{
  "name": "{{ bakery.project_slug | replace('_', '-') }}-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@10.0.0",
  "engines": { "node": ">=24", "pnpm": ">=10" },
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "typecheck": "tsc -b --noEmit",
    "lint": "eslint . --max-warnings=0"
  },
  "dependencies": {
    "react": "^{{ bakery.versions.react }}",
    "react-dom": "^{{ bakery.versions['react-dom'] }}"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^{{ bakery.versions['@vitejs/plugin-react'] }}",
    "vite": "^{{ bakery.versions.vite }}",
    "typescript": "^{{ bakery.versions.typescript }}",
    "eslint": "^{{ bakery.versions.eslint }}",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.1.0"
  }
}
