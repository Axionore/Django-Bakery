name: {{ bakery.project_slug }}_local

services:
  django: &django
    build:
      context: .
      dockerfile: compose/local/django/Dockerfile
    image: {{ bakery.project_slug }}_local_django
    env_file:
      - .env
    environment:
      DJANGO_SETTINGS_MODULE: config.settings.local
    volumes:
      - .:/app:cached
    depends_on:
{%- if bakery.is_postgres %}
      postgres:
        condition: service_healthy
{%- endif %}
{%- if bakery.use_mailpit %}
      mailpit:
        condition: service_started
{%- endif %}
{%- if bakery.use_celery and bakery.celery_broker == 'redis' %}
      redis:
        condition: service_started
{%- endif %}
{%- if bakery.use_celery and bakery.celery_broker == 'rabbitmq' %}
      rabbitmq:
        condition: service_started
{%- endif %}
    ports:
      - "8000:8000"
    command: /app/compose/local/django/start

{%- if bakery.is_postgres %}

  postgres:
    image: postgres:18-alpine
    # Single source of truth for credentials: `.env` (gitignored, generated by
    # `django-bakery new` with a random password). Both Django's DATABASE_URL
    # and Postgres' init use the same POSTGRES_* values, so the auth flow
    # stays in sync — and rotating the password is a one-line `.env` edit.
    env_file:
      - .env
    environment:
      POSTGRES_DB: ${POSTGRES_DB:-{{ bakery.project_slug }}}
      POSTGRES_USER: ${POSTGRES_USER:-postgres}
    volumes:
      # Postgres 18 changed the recommended mount point from
      # `/var/lib/postgresql/data` (PG ≤17) to `/var/lib/postgresql` (PG 18+) —
      # see https://github.com/docker-library/postgres/pull/1259. Mounting at
      # the parent dir lets `pg_upgrade --link` work cleanly across versions.
      - postgres_data:/var/lib/postgresql
      - postgres_data_backups:/backups
    healthcheck:
      # Honor the same POSTGRES_USER / POSTGRES_DB overrides as the env block
      # above — hardcoding `-U postgres -d {{ bakery.project_slug }}` here
      # silently breaks the stack when `.env` sets either to a non-default value
      # (pg_isready returns 2, healthcheck stays unhealthy, every dependent
      # service hangs forever on `depends_on: { condition: service_healthy }`).
      test:
        - "CMD-SHELL"
        - "pg_isready -U ${POSTGRES_USER:-postgres} -d ${POSTGRES_DB:-{{ bakery.project_slug }}}"
      interval: 5s
      timeout: 3s
      retries: 12
    # Bind only to localhost — Postgres reaches Django over the internal compose
    # network anyway, exposing on 0.0.0.0 was an OWASP A05 misconfiguration default
    # (any other process on the host could hit the DB). For GUI clients, use
    # `docker compose exec postgres psql` or change to a different host port.
    ports:
      - "127.0.0.1:5432:5432"
{%- endif %}

{%- if bakery.use_mailpit %}

  mailpit:
    image: axllent/mailpit:latest
    ports:
      - "1025:1025"  # SMTP
      - "8025:8025"  # Web UI
{%- endif %}

{%- if bakery.use_celery and bakery.celery_broker == 'redis' %}

  redis:
    image: redis:8-alpine
    # See compose.production.yml — same `$$REDIS_PASSWORD` pass-through pattern.
    command: redis-server --requirepass $${REDIS_PASSWORD}
    env_file:
      - .env
    volumes:
      - redis_data:/data
    ports:
      - "6379:6379"
{%- endif %}

{%- if bakery.use_celery and bakery.celery_broker == 'rabbitmq' %}

  rabbitmq:
    image: rabbitmq:4-management-alpine
    ports:
      - "5672:5672"
      - "15672:15672"
{%- endif %}

{%- if bakery.has_frontend_spa %}

  frontend:
    image: node:24-alpine
    working_dir: /workspace/frontend
    env_file:
      - .env
    environment:
      VITE_BACKEND_URL: http://django:8000
{%- if bakery.frontend == 'nuxt' %}
      NITRO_BACKEND_URL: http://django:8000
{%- endif %}
    volumes:
      - .:/workspace
      - frontend_node_modules:/workspace/frontend/node_modules
    ports:
      - "{{ bakery.frontend_dev_port }}:{{ bakery.frontend_dev_port }}"
    command: >
      sh -c "corepack enable pnpm &&
             pnpm install --frozen-lockfile=false &&
             pnpm dev"
    depends_on:
      django:
        condition: service_started
{%- endif %}

{%- if bakery.use_celery %}

  celery_worker:
    <<: *django
    image: {{ bakery.project_slug }}_local_celery_worker
    depends_on:
      django:
        condition: service_started
{%- if bakery.celery_broker == 'redis' %}
      redis:
        condition: service_started
{%- else %}
      rabbitmq:
        condition: service_started
{%- endif %}
    ports: []
    command: /app/compose/local/django/celery/worker/start

  celery_beat:
    <<: *django
    image: {{ bakery.project_slug }}_local_celery_beat
    depends_on:
      django:
        condition: service_started
{%- if bakery.celery_broker == 'redis' %}
      redis:
        condition: service_started
{%- else %}
      rabbitmq:
        condition: service_started
{%- endif %}
    ports: []
    command: /app/compose/local/django/celery/beat/start

  flower:
    <<: *django
    image: {{ bakery.project_slug }}_local_flower
    ports:
      - "5555:5555"
    command: /app/compose/local/django/celery/flower/start
{%- endif %}

volumes:
{%- if bakery.is_postgres %}
  postgres_data: {}
  postgres_data_backups: {}
{%- endif %}
{%- if bakery.use_celery and bakery.celery_broker == 'redis' %}
  redis_data: {}
{%- endif %}
{%- if bakery.has_frontend_spa %}
  frontend_node_modules: {}
{%- endif %}
