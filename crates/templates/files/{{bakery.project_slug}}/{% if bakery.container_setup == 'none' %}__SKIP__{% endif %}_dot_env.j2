# =============================================================================
# {{ bakery.project_name }} — LOCAL environment (GENERATED, gitignored)
#
# Generated by `django-bakery new` with fresh strong secrets so the local stack
# runs out of the box: `docker compose -f compose.local.yml up`.
# NEVER commit this file, and NEVER reuse these values in production — for prod,
# copy `.env.example`, fill in real secrets, and use compose.production.yml.
# =============================================================================

# --- Django core ---
DJANGO_SETTINGS_MODULE=config.settings.local
DJANGO_SECRET_KEY={{ bakery.django_secret_key }}
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS={{ bakery.allowed_hosts }}
DJANGO_DEFAULT_FROM_EMAIL=noreply@{{ bakery.domain_name }}
# Defends against admin-URL scanners. Rotate by editing this value.
DJANGO_ADMIN_URL=admin-{{ bakery.admin_url_suffix }}/

# --- Initial superuser (seeded idempotently on first boot) ---
DJANGO_SUPERUSER_EMAIL={{ bakery.superuser_email }}
DJANGO_SUPERUSER_PASSWORD={{ bakery.superuser_password }}

# --- Database ---
{%- if bakery.is_postgres %}
DATABASE_URL=postgres://postgres:{{ bakery.db_password }}@postgres:5432/{{ bakery.project_slug }}
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB={{ bakery.project_slug }}
POSTGRES_USER=postgres
POSTGRES_PASSWORD={{ bakery.db_password }}
{%- elif bakery.is_sqlite %}
DATABASE_URL=sqlite:///./db.sqlite3
{%- else %}
DATABASE_URL=mysql://root:{{ bakery.db_password }}@mysql:3306/{{ bakery.project_slug }}
MYSQL_ROOT_PASSWORD={{ bakery.db_password }}
MYSQL_DATABASE={{ bakery.project_slug }}
{%- endif %}

{%- if bakery.use_mailpit %}

# --- Email (local dev → Mailpit) ---
EMAIL_HOST=mailpit
EMAIL_PORT=1025
{%- endif %}

{%- if bakery.use_celery %}

# --- Celery ---
{%- if bakery.celery_broker == 'redis' %}
REDIS_PASSWORD={{ bakery.redis_password }}
CELERY_BROKER_URL=redis://:${REDIS_PASSWORD}@redis:6379/0
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/0
{%- else %}
CELERY_BROKER_URL=amqp://rabbitmq:5672/
{%- endif %}
CELERY_FLOWER_USER={{ bakery.flower_user }}
CELERY_FLOWER_PASSWORD={{ bakery.flower_password }}
{%- endif %}

# --- CORS (SPA origins) ---
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Tooling ---
USE_DEBUG_TOOLBAR=True

# --- Security toggles (default to safe; never disable in production) ---
STAFF_MFA_REQUIRED=True
