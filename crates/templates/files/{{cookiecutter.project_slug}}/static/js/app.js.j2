// Project-level JS entry point.
//
// HTMX + Alpine.js are loaded via <script> tags in base.html — this file is for any
// project-specific glue you need.

{%- if cookiecutter.frontend == 'htmx-alpine' %}
// Configure HTMX defaults — CSRF token forwarding for Django.
document.body.addEventListener("htmx:configRequest", (event) => {
  const csrfToken = document.querySelector("[name=csrfmiddlewaretoken]")?.value;
  if (csrfToken) {
    event.detail.headers["X-CSRFToken"] = csrfToken;
  }
});

// Re-initialize Alpine on HTMX swaps so newly-inserted DOM nodes get their `x-*` directives.
document.body.addEventListener("htmx:afterSwap", (event) => {
  if (window.Alpine && event.detail?.target) {
    window.Alpine.initTree(event.detail.target);
  }
});
{%- endif %}

console.info("{{ cookiecutter.project_name }} — frontend ready");
