"""Test settings — in-memory DB where possible, fast hashers, deterministic email."""

from __future__ import annotations

from .base import *  # noqa: F401,F403
from .base import env  # noqa: F401

DEBUG = False
SECRET_KEY = "test-secret-not-for-anything-real"  # noqa: S105
ALLOWED_HOSTS = ["*"]

# Disable MFA-enforcement middleware in tests so factories can log in as staff without
# walking the full TOTP enrollment flow. Tests that exercise enrollment opt in explicitly
# via @override_settings(STAFF_MFA_REQUIRED=True).
STAFF_MFA_REQUIRED = False

# Fast password hashing in tests. MD5 is cryptographically broken; this is OK ONLY
# because pytest is the one importing this module. Catch the dangerous case where
# someone accidentally points DJANGO_SETTINGS_MODULE=config.settings.test at a
# real environment (e.g. staging) — abort startup before any password is stored.
import os as _os
import sys as _sys

if not (
    _os.environ.get("PYTEST_CURRENT_TEST")
    or _os.environ.get("CI")
    or "pytest" in _sys.argv[0]
    or any("pytest" in arg for arg in _sys.argv)
):
    raise RuntimeError(
        "config.settings.test is for the pytest suite ONLY. "
        "Detected non-test invocation — refusing to load MD5 password hasher. "
        "Set DJANGO_SETTINGS_MODULE=config.settings.local or .production instead."
    )

PASSWORD_HASHERS = ["django.contrib.auth.hashers.MD5PasswordHasher"]

# In-memory locmem cache + collected email
EMAIL_BACKEND = "django.core.mail.backends.locmem.EmailBackend"
CACHES = {"default": {"BACKEND": "django.core.cache.backends.locmem.LocMemCache"}}

