"""Idempotent: ensures the `public` Tenant + its Domain exist.

django-tenants requires a tenant row in the `public` schema before any
request can be routed (the middleware looks up the Tenant by Domain
hostname on every request — no public Tenant means HTTP 404 everywhere).

Run once after `migrate_schemas --shared` on first deploy:

    uv run python manage.py bootstrap_public_tenant

Idempotent — safe to re-run.
"""

from __future__ import annotations

from django.core.management.base import BaseCommand

from apps.tenants.models import Domain, Tenant


class Command(BaseCommand):
    help = "Create the `public` Tenant + Domain if they don't exist yet."

    def handle(self, *args, **options) -> None:  # type: ignore[no-untyped-def]
        public, created = Tenant.objects.get_or_create(
            schema_name="public",
            defaults={"name": "Public", "on_trial": False, "paid_until": None},
        )
        if created:
            self.stdout.write(self.style.SUCCESS("Created public Tenant"))
        domain, created = Domain.objects.get_or_create(
            domain="{{ cookiecutter.domain_name }}",
            defaults={"tenant": public, "is_primary": True},
        )
        if created:
            self.stdout.write(self.style.SUCCESS(
                f"Routed {domain.domain} → public schema"
            ))
        self.stdout.write(self.style.SUCCESS("Public tenant ready."))
