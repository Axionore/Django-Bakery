{
  "name": "{{ cookiecutter.project_slug | replace('_', '-') }}-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@10.0.0",
  "engines": { "node": ">=24", "pnpm": ">=10" },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "esbuild",
      "unrs-resolver",
      "sharp"
    ]
  },
  "scripts": {
    "dev": "next dev --port {{ cookiecutter.frontend_dev_port }}",
    "build": "next build",
    "start": "next start --port {{ cookiecutter.frontend_dev_port }}",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test"{% if cookiecutter.has_typed_api %},
    "openapi:gen": "openapi-typescript http://localhost:8000/api/openapi.json -o lib/api/schema.d.ts"{% endif %}
  },
  "dependencies": {
    "next": "^16.0.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "@radix-ui/themes": "^3.3.0",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/colors": "^3.0.0",
    "@tanstack/react-query": "^5.62.0",
    "zustand": "^5.0.2",
    "zod": "^4.4.0"{% if cookiecutter.use_sentry %},
    "@sentry/nextjs": "^9.0.0"{% endif %}
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "typescript": "^6.0.2",
    "eslint": "^10.0.0",
    "eslint-config-next": "^16.0.0",
    "prettier": "^3.8.1",
    "vitest": "^4.1.0",
    "@vitest/coverage-v8": "^4.1.0",
    "jsdom": "^29.0.0",
    "@testing-library/react": "^16.1.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@playwright/test": "^1.50.0"{% if cookiecutter.has_typed_api %},
    "openapi-typescript": "^7.4.4"{% endif %}
  }
}
