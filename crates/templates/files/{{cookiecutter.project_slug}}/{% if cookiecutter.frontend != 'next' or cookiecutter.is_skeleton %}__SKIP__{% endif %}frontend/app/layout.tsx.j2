import type { Metadata } from "next";
import "~/styles/globals.css";

import { Providers } from "~/app/providers";
import { Nav } from "~/lib/ui/nav";
import { currentUser } from "~/lib/auth/server";

const NAME = "{{ cookiecutter.project_name }}";
const DESCRIPTION = "{{ cookiecutter.description }}";

export const metadata: Metadata = {
  title: { default: NAME, template: `%s · ${NAME}` },
  description: DESCRIPTION,
};

{% raw %}
export default async function RootLayout({
  children,
}: Readonly<{ children: React.ReactNode }>) {
  // Server-side session read — runs on every request. The result is passed
  // into <Providers initialUser=…> so the first paint already reflects auth
  // state without a client-side waterfall.
  const user = await currentUser();

  return (
    <html lang="en" suppressHydrationWarning>
      <body style={{ margin: 0, minHeight: "100dvh", display: "flex", flexDirection: "column" }}>
        <Providers initialUser={user}>
          <Nav />
          <main style={{ flex: 1, padding: "1.5rem 1rem" }}>{children}</main>
          <footer style={{ borderTop: "1px solid var(--gray-a4)", padding: "1rem", fontSize: 12, color: "var(--gray-10)" }}>
            <div style={{ maxWidth: 1024, margin: "0 auto", display: "flex", justifyContent: "space-between" }}>
              <span>© {new Date().getFullYear()} · powered by django-bakery</span>
              <a href="https://github.com/Axionore/Django-Barkery" target="_blank" rel="noreferrer">
                source
              </a>
            </div>
          </footer>
        </Providers>
      </body>
    </html>
  );
}
{% endraw %}
