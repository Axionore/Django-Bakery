import { Box, Container, Flex, Heading, Table, Text } from "@radix-ui/themes";

export const metadata = { title: "About" };

const DESCRIPTION = "{{ cookiecutter.description }}";
const ROWS: Array<[string, string]> = [
  ["Backend", "Django {{ cookiecutter.django_version }} · Python {{ cookiecutter.python_version }}"],
  ["Frontend", "Next.js 16 · React 19 · TypeScript 6 · Radix Themes 4"],
{%- if cookiecutter.api_layer != 'none' %}
  ["API", "{{ cookiecutter.api_layer }}"],
{%- endif %}
  ["Auth", "django-allauth headless · MFA TOTP · Argon2id · session cookies"],
];

{% raw %}
export default function AboutPage() {
  return (
    <Container size="3">
      <Flex direction="column" gap="5" py="6" style={{ maxWidth: 720 }}>
        <Heading size="8">About</Heading>
        <Text as="p" size="3" color="gray">
          {DESCRIPTION}
        </Text>
        <Box>
          <Heading size="5" mb="3">
            Stack
          </Heading>
          <Table.Root variant="surface">
            <Table.Body>
              {ROWS.map(([label, value]) => (
                <Table.Row key={label}>
                  <Table.RowHeaderCell>{label}</Table.RowHeaderCell>
                  <Table.Cell>{value}</Table.Cell>
                </Table.Row>
              ))}
            </Table.Body>
          </Table.Root>
        </Box>
      </Flex>
    </Container>
  );
}
{% endraw %}
