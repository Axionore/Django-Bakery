{%- if cookiecutter.has_typed_api %}
/**
 * Typed `/api/*` client.
 *
 * Backend is {{ cookiecutter.api_layer }} — uses Django session authentication.
 *   - Ninja: https://django-ninja.dev/guides/authentication/
 *   - DRF:   https://www.django-rest-framework.org/api-guide/authentication/
 *
 * BROWSER-side (Client Components): use the helpers below — they rely on
 * the same-origin rewrite in next.config.ts to forward cookies + CSRF.
 *
 * SERVER-side (Server Components / Server Actions): forward the user's cookie
 * via `next/headers` — see `lib/auth/server.ts` for the pattern. NEVER call
 * these helpers from a Server Component; the rewrite isn't active there.
 *
 * Regenerate the typed schema:    pnpm openapi:gen
 */

import { csrfHeaders } from "~/lib/auth/csrf";

export class HttpError extends Error {
  constructor(public status: number, public body: unknown) {
    super(`HTTP ${status}`);
    this.name = "HttpError";
  }
}

const BASE = "/api";

export async function apiGet<T>(path: string): Promise<T> {
  const r = await fetch(`${BASE}${path}`, {
    credentials: "include",
    headers: { Accept: "application/json" },
  });
  if (!r.ok) throw new HttpError(r.status, await r.json().catch(() => null));
  return (await r.json()) as T;
}

export async function apiSend<T>(
  method: "POST" | "PUT" | "PATCH" | "DELETE",
  path: string,
  body?: unknown,
): Promise<T> {
  const r = await fetch(`${BASE}${path}`, {
    method,
    credentials: "include",
    headers: csrfHeaders({ Accept: "application/json" }),
    body: body === undefined ? undefined : JSON.stringify(body),
  });
  if (!r.ok) throw new HttpError(r.status, await r.json().catch(() => null));
  if (r.status === 204) return undefined as T;
  return (await r.json()) as T;
}

export async function fetchMe(): Promise<{
  id: number;
  email: string;
  full_name: string;
  is_staff: boolean;
}> {
  return apiGet("/me");
}
{% else %}
// No API layer was selected. Pick one in the recipe to get a typed client.
export {};
{% endif -%}
