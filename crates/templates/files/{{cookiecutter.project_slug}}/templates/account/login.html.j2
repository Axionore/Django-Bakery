{% raw %}{% extends "base.html" %}
{% load i18n allauth account %}{% endraw %}

{% raw %}{% block title %}Sign in{% endblock %}{% endraw %}

{% raw %}{% block content %}{% endraw %}
<section class="mx-auto max-w-md">
    <h1 class="text-2xl font-semibold">Sign in to {{ cookiecutter.project_name }}</h1>
    <p class="mt-2 text-sm text-slate-600">Use your email and password.</p>
    <form method="post" action="{% raw %}{% url 'account_login' %}{% endraw %}" class="mt-6 space-y-4">
        {% raw %}{% csrf_token %}
        {{ form.as_p }}{% endraw %}
        <button type="submit" class="rounded-md bg-slate-900 px-4 py-2 text-sm font-medium text-white hover:bg-slate-700">
            Sign in
        </button>
        <a href="{% raw %}{% url 'account_reset_password' %}{% endraw %}" class="ml-3 text-sm hover:underline">Forgot password?</a>
    </form>
    <p class="mt-6 text-sm text-slate-600">
        Don't have an account?
        <a href="{% raw %}{% url 'account_signup' %}{% endraw %}" class="underline">Sign up</a>
    </p>
</section>
{% raw %}{% endblock %}{% endraw %}
