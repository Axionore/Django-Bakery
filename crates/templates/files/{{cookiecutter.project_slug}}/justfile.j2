set dotenv-load := true
set shell := ["bash", "-cu"]

PROJECT := "{{ cookiecutter.project_slug }}"

# Show all recipes.
@default:
    just --list --unsorted

# --- environment ----------------------------------------------------------
# Install / sync Python dependencies.
sync:
    uv sync
{% if cookiecutter.frontend == 'htmx-alpine' and cookiecutter.css_framework == 'tailwind' %}
# --- css build (Tailwind v4) ---------------------------------------------
# Install the Tailwind CLI (one-time per machine / clone).
css-install:
    pnpm install --ignore-scripts

# Compile `static/css/app.css` → `static/css/app.compiled.css` (minified).
# Run after pulling, after editing the Tailwind source, and before deploy.
css-build:
    pnpm css:build

# Watch the source file and recompile on change — leave this running during dev.
css-watch:
    pnpm css:watch
{% endif %}
# Run the dev server (no Docker).
serve:
    uv run python manage.py runserver 0.0.0.0:8000

# --- database -------------------------------------------------------------
makemigrations *args:
    uv run python manage.py makemigrations {{'{{args}}'}}

migrate *args:
    uv run python manage.py migrate {{'{{args}}'}}

shell:
    uv run python manage.py shell_plus --ipython

# --- i18n -----------------------------------------------------------------
# Extract all `gettext`-marked strings from .py + Django templates into a
# `.po` per locale under `locale/<lang>/LC_MESSAGES/django.po`. The first
# `--locale=` arg defines the language to extract for; defaults to French.
makemessages *locales:
    uv run python manage.py makemessages --locale {{'{{locales}}'}} || \
        uv run python manage.py makemessages --locale fr

# Compile the `.po` files into the binary `.mo` form Django serves at runtime.
compilemessages:
    uv run python manage.py compilemessages

# --- quality --------------------------------------------------------------
fmt:
    uv run ruff check --fix .
    uv run ruff format .
    uv run djlint --reformat templates/

lint:
    uv run ruff check .
    uv run djlint --check templates/
{% if cookiecutter.type_checker == 'mypy' %}    uv run mypy .{% elif cookiecutter.type_checker == 'pyright' %}    uv run pyright{% endif %}

test *args:
    uv run pytest {{'{{args}}'}}

cov:
    uv run pytest --cov=apps --cov=config --cov-report=term-missing --cov-report=html

# --- docker ---------------------------------------------------------------
{%- if cookiecutter.container_setup != 'none' %}
up:
    docker compose -f compose.local.yml up --build

down:
    docker compose -f compose.local.yml down

logs *args:
    docker compose -f compose.local.yml logs -f {{'{{args}}'}}

prod-up:
    docker compose -f compose.production.yml up -d --build

prod-down:
    docker compose -f compose.production.yml down
{%- endif %}

# --- security -------------------------------------------------------------
audit:
    uv run pip-audit
    uv tool run --from gitleaks gitleaks dir .

# Production deploy checklist (collectstatic, migrate, check --deploy).
deploy-check:
    uv run python manage.py check --deploy --fail-level=WARNING
    uv run python manage.py collectstatic --noinput --dry-run

# Create a superuser interactively (or pass --email + --password).
superuser:
    uv run python manage.py createsuperuser
