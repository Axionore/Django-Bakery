{
  "name": "{{ cookiecutter.project_slug | replace('_', '-') }}-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@10.0.0",
  "engines": { "node": ">=24", "pnpm": ">=10" },
  "scripts": {
    "dev": "nuxt dev",
    "build": "nuxt build",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "typecheck": "nuxt typecheck",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test"{% if cookiecutter.has_typed_api %},
    "openapi:gen": "openapi-typescript http://localhost:8000/api/openapi.json -o app/types/api-schema.d.ts"{% endif %}
  },
  "dependencies": {
    "nuxt": "^4.1.0",
    "vue": "^3.6.0",
    "vue-router": "^4.5.0",
    "@pinia/nuxt": "^0.11.0",
    "pinia": "^3.0.0",
    "@nuxtjs/tailwindcss": "^7.0.0",
    "tailwindcss": "^4.1.0",
    "@vueuse/nuxt": "^11.0.0",
    "zod": "^4.0.0"{% if cookiecutter.use_sentry %},
    "@sentry/nuxt": "^9.0.0"{% endif %}
  },
  "devDependencies": {
    "@nuxt/eslint": "^1.0.0",
    "@nuxt/test-utils": "^3.20.0",
    "@vue/test-utils": "^3.0.0",
    "typescript": "^6.0.2",
    "eslint": "^9.39.0",
    "prettier": "^3.8.1",
    "vitest": "^8.0.0",
    "@vitest/coverage-v8": "^8.0.0",
    "happy-dom": "^16.0.0",
    "@playwright/test": "^1.50.0"{% if cookiecutter.has_typed_api %},
    "openapi-typescript": "^7.4.4"{% endif %}
  }
}
