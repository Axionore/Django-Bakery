{
  "name": "{{ cookiecutter.project_slug | replace('_', '-') }}-css",
  "private": true,
  "version": "0.1.0",
  "description": "Tailwind v4 build for the server-rendered Django + HTMX project. The only Node touchpoint — at runtime the site is HTML+CSS+HTMX, no bundle.",
  "packageManager": "pnpm@10.0.0",
  "engines": { "node": ">=24", "pnpm": ">=10" },
  "scripts": {
    "css:build": "tailwindcss -i ./static/css/app.css -o ./static/css/app.compiled.css --minify",
    "css:watch": "tailwindcss -i ./static/css/app.css -o ./static/css/app.compiled.css --watch"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.0",
    "tailwindcss": "^4.3.0"
  }
}
