{
  "name": "{{ cookiecutter.project_slug | replace('_', '-') }}-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@10.0.0",
  "engines": { "node": ">=24", "pnpm": ">=10" },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "esbuild",
      "unrs-resolver"
    ]
  },
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "vue-tsc --build && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test"{% if cookiecutter.has_typed_api %},
    "openapi:gen": "openapi-typescript http://localhost:8000/api/openapi.json -o src/api/schema.d.ts"{% endif %}
  },
  "dependencies": {
    "vue": "^3.5.0",
    "vue-router": "^4.5.0",
    "pinia": "^3.0.0",
    "@vueuse/core": "^14.0.0",
    "zod": "^4.4.0"{% if cookiecutter.use_sentry %},
    "@sentry/vue": "^9.0.0"{% endif %}
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@vitejs/plugin-vue": "^6.0.0",
    "vite": "^8.0.0",
    "vue-tsc": "^3.0.0",
    "typescript": "^6.0.2",
    "tailwindcss": "^4.3.0",
    "@tailwindcss/vite": "^4.3.0",
    "eslint": "^10.0.0",
    "eslint-plugin-vue": "^10.0.0",
    "@vue/eslint-config-typescript": "^14.5.0",
    "prettier": "^3.8.1",
    "vitest": "^4.1.0",
    "@vitest/coverage-v8": "^4.1.0",
    "@vue/test-utils": "^2.4.0",
    "happy-dom": "^20.0.0",
    "@playwright/test": "^1.50.0"{% if cookiecutter.has_typed_api %},
    "openapi-typescript": "^7.4.4"{% endif %}
  }
}
