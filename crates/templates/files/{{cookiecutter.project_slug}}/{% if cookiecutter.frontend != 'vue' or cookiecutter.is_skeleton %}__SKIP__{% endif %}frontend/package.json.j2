{
  "name": "{{ cookiecutter.project_slug | replace('_', '-') }}-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@10.0.0",
  "engines": { "node": ">=24", "pnpm": ">=10" },
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "vue-tsc --build && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test"{% if cookiecutter.has_typed_api %},
    "openapi:gen": "openapi-typescript http://localhost:8000/api/openapi.json -o src/api/schema.d.ts"{% endif %}
  },
  "dependencies": {
    "vue": "^{{ bakery.versions.vue }}",
    "vue-router": "^{{ bakery.versions['vue-router'] }}",
    "pinia": "^{{ bakery.versions.pinia }}",
    "@vueuse/core": "^{{ bakery.versions['@vueuse/core'] }}",
    "zod": "^{{ bakery.versions.zod }}"{% if cookiecutter.use_sentry %},
    "@sentry/vue": "^9.0.0"{% endif %}
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@vitejs/plugin-vue": "^{{ bakery.versions['@vitejs/plugin-vue'] }}",
    "vite": "^{{ bakery.versions.vite }}",
    "vue-tsc": "^3.0.0",
    "typescript": "^{{ bakery.versions.typescript }}",
    "tailwindcss": "^{{ bakery.versions.tailwindcss }}",
    "@tailwindcss/vite": "^{{ bakery.versions['@tailwindcss/vite'] }}",
    "eslint": "^{{ bakery.versions.eslint }}",
    "eslint-plugin-vue": "^10.0.0",
    "@vue/eslint-config-typescript": "^14.5.0",
    "prettier": "^{{ bakery.versions.prettier }}",
    "vitest": "^{{ bakery.versions.vitest }}",
    "@vitest/coverage-v8": "^{{ bakery.versions['@vitest/coverage-v8'] }}",
    "@vue/test-utils": "^{{ bakery.versions['@vue/test-utils'] }}",
    "happy-dom": "^{{ bakery.versions['happy-dom'] }}",
    "@playwright/test": "^{{ bakery.versions['@playwright/test'] }}"{% if cookiecutter.has_typed_api %},
    "openapi-typescript": "^{{ bakery.versions['openapi-typescript'] }}"{% endif %}
  }
}
