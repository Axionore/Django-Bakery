name: {{ cookiecutter.project_slug }}_production

services:
  django: &django
    build:
      context: .
      dockerfile: compose/production/django/Dockerfile
    image: {{ cookiecutter.project_slug }}_production_django
    env_file:
      - .env
    environment:
      DJANGO_SETTINGS_MODULE: config.settings.production
    depends_on:
{%- if cookiecutter.is_postgres %}
      postgres:
        condition: service_healthy
{%- endif %}
{%- if cookiecutter.use_celery and cookiecutter.celery_broker == 'redis' %}
      - redis
{%- endif %}
    command: /start
    restart: unless-stopped
{%- if cookiecutter.container_setup == 'compose-traefik' %}
    labels:
      - "traefik.enable=true"
      - "traefik.http.routers.web.rule=Host(`{{ cookiecutter.domain_name }}`)"
      - "traefik.http.routers.web.entrypoints=websecure"
      - "traefik.http.routers.web.tls=true"
      - "traefik.http.routers.web.tls.certresolver=letsencrypt"
      - "traefik.http.services.web.loadbalancer.server.port=5000"
{%- else %}
    ports:
      - "5000:5000"
{%- endif %}

{%- if cookiecutter.is_postgres %}

  postgres:
    build:
      context: .
      dockerfile: compose/production/postgres/Dockerfile
    image: {{ cookiecutter.project_slug }}_production_postgres
    env_file:
      - .env
    volumes:
      - production_postgres_data:/var/lib/postgresql/data
      - production_postgres_data_backups:/backups
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U postgres -d {{ cookiecutter.project_slug }}"]
      interval: 10s
      timeout: 5s
      retries: 6
    restart: unless-stopped
{%- endif %}

{%- if cookiecutter.use_celery and cookiecutter.celery_broker == 'redis' %}

  redis:
    image: redis:8-alpine
    # Password comes from the gitignored .env (REDIS_PASSWORD). Compose's $$ escape
    # passes the literal `${REDIS_PASSWORD}` to the container's entrypoint, which
    # the container's shell then resolves from its environment.
    command: redis-server --requirepass $${REDIS_PASSWORD} --appendonly yes
    env_file:
      - .env
    volumes:
      - production_redis_data:/data
    restart: unless-stopped
{%- endif %}

{%- if cookiecutter.use_celery %}

  celery_worker:
    <<: *django
    image: {{ cookiecutter.project_slug }}_production_celery_worker
    command: /start-celeryworker
    labels: []
    ports: []

  celery_beat:
    <<: *django
    image: {{ cookiecutter.project_slug }}_production_celery_beat
    command: /start-celerybeat
    labels: []
    ports: []
{%- endif %}

{%- if cookiecutter.container_setup == 'compose-traefik' %}

  traefik:
    build:
      context: .
      dockerfile: compose/production/traefik/Dockerfile
    image: {{ cookiecutter.project_slug }}_production_traefik
    depends_on:
      - django
    volumes:
      - production_traefik:/etc/traefik/acme
    ports:
      - "80:80"
      - "443:443"
    restart: unless-stopped
{%- endif %}

volumes:
{%- if cookiecutter.is_postgres %}
  production_postgres_data: {}
  production_postgres_data_backups: {}
{%- endif %}
{%- if cookiecutter.use_celery and cookiecutter.celery_broker == 'redis' %}
  production_redis_data: {}
{%- endif %}
{%- if cookiecutter.container_setup == 'compose-traefik' %}
  production_traefik: {}
{%- endif %}
