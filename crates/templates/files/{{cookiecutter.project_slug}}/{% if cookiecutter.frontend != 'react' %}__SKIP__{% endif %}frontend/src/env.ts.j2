import { z } from "zod";

/**
 * Validated env vars. Anything the SPA reads from `import.meta.env.*` lives here
 * with a zod schema so a bad value fails fast at app start rather than as a
 * surprise `undefined` deep in the call stack.
 */
const schema = z.object({
  VITE_BACKEND_URL: z.url().default("http://localhost:8000"),
  VITE_APP_NAME: z.string().default("{{ cookiecutter.project_name }}"),
  VITE_SENTRY_DSN: z.string().optional(),
});

export type Env = z.infer<typeof schema>;

let cached: Env | null = null;

export function initEnv(): Env {
  if (cached) return cached;
  const parsed = schema.safeParse(import.meta.env);
  if (!parsed.success) {
    // eslint-disable-next-line no-console
    console.error("Invalid frontend env vars:", parsed.error.flatten().fieldErrors);
    throw new Error("Refusing to start with invalid env. See console for details.");
  }
  cached = parsed.data;
  return cached;
}

export function env(): Env {
  if (!cached) initEnv();
  return cached as Env;
}
