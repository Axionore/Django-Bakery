import { defineConfig } from "vite";
import react from "@vitejs/plugin-react";
import path from "node:path";

// Backend host: `django` in Docker Compose; `localhost:8000` when running bare.
const BACKEND = process.env.VITE_BACKEND_URL ?? "http://localhost:8000";

export default defineConfig({
  plugins: [react()],
  resolve: {
    alias: { "~": path.resolve(__dirname, "src") },
  },
  server: {
    host: "0.0.0.0",
    port: {{ cookiecutter.frontend_dev_port }},
    strictPort: true,
    proxy: {
      // Cookies + CSRF require same-origin in dev. The Vite dev server proxies
      // both auth and API to the Django backend so the SPA fetches stay
      // first-party from the browser's point of view.
      "/api": { target: BACKEND, changeOrigin: true, secure: false },
      "/_allauth": { target: BACKEND, changeOrigin: true, secure: false },
      "/static": { target: BACKEND, changeOrigin: true, secure: false },
      "/media": { target: BACKEND, changeOrigin: true, secure: false },
    },
    hmr: { port: {{ cookiecutter.frontend_dev_port }} },
  },
  build: {
    outDir: "dist",
    target: "es2024",
    sourcemap: false,
    rollupOptions: {
      output: {
        manualChunks: {
          react: ["react", "react-dom", "react-router"],
          radix: ["@radix-ui/themes", "@radix-ui/react-icons"],
        },
      },
    },
    chunkSizeWarningLimit: 250, // KB — see spec acceptance criteria
  },
  test: undefined, // configured in vitest.config.ts
});
