# =============================================================================
# {{ cookiecutter.project_name }} — environment variables
#
# Copy to `.env` and fill in. NEVER commit the real `.env`.
#
# Every value marked `<GENERATE>` MUST be replaced with a fresh random secret.
# Generate one with:    python -c "import secrets; print(secrets.token_urlsafe(48))"
# Or use the project's own helper:    just superuser   (also rotates SECRET_KEY)
# =============================================================================

# --- Django core ---
DJANGO_SETTINGS_MODULE=config.settings.local
DJANGO_SECRET_KEY=<GENERATE-50-char-secret>
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
DJANGO_DEFAULT_FROM_EMAIL=noreply@{{ cookiecutter.domain_name }}
# Defends against admin-URL scanners. Rotate by editing this value.
DJANGO_ADMIN_URL=admin-{{ bakery.admin_url_suffix }}/

# --- Database ---
{%- if cookiecutter.is_postgres %}
DATABASE_URL=postgres://postgres:<GENERATE-postgres-password>@postgres:5432/{{ cookiecutter.project_slug }}
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB={{ cookiecutter.project_slug }}
POSTGRES_USER=postgres
POSTGRES_PASSWORD=<GENERATE-postgres-password>
{%- elif cookiecutter.is_sqlite %}
DATABASE_URL=sqlite:///./db.sqlite3
{%- else %}
DATABASE_URL=mysql://root:<GENERATE-mysql-password>@mysql:3306/{{ cookiecutter.project_slug }}
{%- endif %}

# --- Email (local dev → Mailpit) ---
{%- if cookiecutter.use_mailpit %}
EMAIL_HOST=mailpit
EMAIL_PORT=1025
{%- endif %}

{%- if cookiecutter.use_celery %}
# --- Celery ---
{%- if cookiecutter.celery_broker == 'redis' %}
REDIS_PASSWORD=<GENERATE-redis-password>
CELERY_BROKER_URL=redis://:${REDIS_PASSWORD}@redis:6379/0
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/0
{%- else %}
CELERY_BROKER_URL=amqp://rabbitmq:5672/
{%- endif %}

# --- Celery Flower (required — no insecure defaults) ---
CELERY_FLOWER_USER=<GENERATE-flower-username>
CELERY_FLOWER_PASSWORD=<GENERATE-flower-password>
{%- endif %}

{%- if cookiecutter.use_celery or cookiecutter.is_postgres %}

# --- Production-only secrets (placeholders) ---
{%- endif %}
{%- if cookiecutter.storage == 'aws-s3' %}
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=us-east-1
{%- endif %}
{%- if cookiecutter.prod_email == 'anymail-mailgun' %}
MAILGUN_API_KEY=
MAILGUN_DOMAIN={{ cookiecutter.domain_name }}
{%- elif cookiecutter.prod_email == 'anymail-ses' %}
# AWS SES uses the standard AWS credential chain (env / instance role / SSO).
# Set AWS_ACCESS_KEY_ID + AWS_SECRET_ACCESS_KEY here ONLY if you cannot use
# an IAM role at runtime. AWS_SES_REGION_NAME selects the SES endpoint.
AWS_SES_REGION_NAME=us-east-1
{%- elif cookiecutter.prod_email == 'anymail-sendgrid' %}
SENDGRID_API_KEY=
{%- elif cookiecutter.prod_email == 'anymail-mailjet' %}
MAILJET_API_KEY=
MAILJET_SECRET_KEY=
{%- elif cookiecutter.prod_email == 'anymail-mandrill' %}
MANDRILL_API_KEY=
{%- elif cookiecutter.prod_email == 'anymail-postmark' %}
POSTMARK_SERVER_TOKEN=
{%- elif cookiecutter.prod_email == 'anymail-brevo' %}
BREVO_API_KEY=
{%- elif cookiecutter.prod_email == 'anymail-sparkpost' %}
SPARKPOST_API_KEY=
{%- endif %}
{%- if cookiecutter.use_sentry %}
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1
{%- endif %}
{%- if cookiecutter.use_observability %}
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME={{ cookiecutter.project_slug }}
{%- endif %}

# --- CORS (SPA origins) ---
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Tooling ---
USE_DEBUG_TOOLBAR=True

# --- Security toggles (default to safe; never disable in production) ---
STAFF_MFA_REQUIRED=True
