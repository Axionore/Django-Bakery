#!/usr/bin/env bash
set -euo pipefail

# Custom AUTH_USER_MODEL needs its initial migration before `migrate` runs —
# Django refuses migrations that depend on `users` if the app has no
# migrations directory of its own. After the first boot the generated
# migration is committed to the repo and this becomes a no-op.
uv run python manage.py makemigrations users --noinput
uv run python manage.py migrate --noinput
uv run python manage.py runserver 0.0.0.0:8000
