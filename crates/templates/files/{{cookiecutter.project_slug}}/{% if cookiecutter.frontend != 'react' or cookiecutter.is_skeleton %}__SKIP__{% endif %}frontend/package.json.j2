{
  "name": "{{ cookiecutter.project_slug | replace('_', '-') }}-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@10.0.0",
  "engines": {
    "node": ">=24",
    "pnpm": ">=10"
  },
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "typecheck": "tsc -b --noEmit"{% if cookiecutter.has_typed_api %},
    "openapi:gen": "openapi-typescript http://localhost:8000/api/openapi.json -o src/api/schema.d.ts"{% endif %}
  },
  "dependencies": {
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router": "^7.15.0",
    "@radix-ui/themes": "^3.3.0",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/colors": "^3.0.0",
    "@tanstack/react-query": "^5.62.0",
    "zustand": "^5.0.2",
    "zod": "^4.4.0"{% if cookiecutter.use_sentry %},
    "@sentry/react": "^9.0.0"{% endif %}
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.0",
    "vite": "^8.0.0",
    "typescript": "^6.0.2",
    "eslint": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "prettier": "^3.8.1",
    "vitest": "^4.1.0",
    "@vitest/coverage-v8": "^4.1.0",
    "jsdom": "^29.0.0",
    "@testing-library/react": "^16.1.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/user-event": "^14.5.2",
    "@playwright/test": "^1.50.0"{% if cookiecutter.has_typed_api %},
    "openapi-typescript": "^7.4.4"{% endif %}
  }
}
