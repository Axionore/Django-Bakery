# IMPORTANT: the embedded template tree contains files that LOOK ignorable
# (`.env.example.j2`, `.vscode/`, `.gitignore`, etc.) but ARE the templates
# we ship. Un-ignore everything under crates/templates/files/.
!crates/templates/files/**
!crates/templates/files/**/.*
